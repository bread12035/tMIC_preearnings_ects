# Example only - the real Secret with the actual ANTHROPIC_API_KEY is NEVER
# committed to Git. Manage it with sealed-secrets, SOPS, External Secrets
# Operator, or `kubectl create secret` from a file kept out of version control.
#
# stringData is auto-base64-encoded by K8s on apply, so plain text is fine here.

apiVersion: v1
kind: Secret
metadata:
  name: earnings-intel-secret
  namespace: tmic
type: Opaque
stringData:
  # The KEY here is the filename. Content is .env-format text.
  secret.env: |
    ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
